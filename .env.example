# .env.example
# Copia este archivo a .env y actualiza los valores según sea necesario

# ==========================================
# BASE DE DATOS POSTGRESQL
# ==========================================
DB_NAME=medical_reserva
DB_USER=medical_user
DB_PASSWORD=medical_secure_pwd_2024
DB_HOST=db
DB_PORT=5432

# ==========================================
# DJANGO SETTINGS
# ==========================================
DEBUG=True
SECRET_KEY=django-insecure-dev-key-only-for-local-development
ALLOWED_HOSTS=localhost,127.0.0.1,medical_web

# ==========================================
# REDIS Y CELERY
# ==========================================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ==========================================
# EMAIL (OPCIONAL)
# ==========================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password

# ==========================================
# TIMEZONE
# ==========================================
TZ=America/Mexico_City

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=INFO
